{
  "name": "blood",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite --open",
    "dev:backend": "convex dev",
    "predev": "convex dev --until-success && convex dashboard",
    "build": "tsc -b && vite build",
    "lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "script:initialize": "node scripts/initialize-standalone.mjs",
    "script:initialize:devnet": "node scripts/initialize-standalone.mjs --cluster=devnet",
    "script:initialize:ts": "ts-node scripts/initialize-game.ts",
    "script:initialize:cjs": "node scripts/initialize-game.cjs",
    "anchor:test": "dotenv -e .env.local -- bash -c 'anchor test --provider.wallet ${ANCHOR_WALLET} --program-name domin8_prgm --program-id ${ANCHOR_PROGRAM_ID}'",
    "anchor:test:skip": "dotenv -e .env.local -- bash -c 'anchor test --skip-build --skip-deploy --provider.wallet ${ANCHOR_WALLET}'",
    "anchor:build": "dotenv -e .env.local -- bash -c 'anchor build'",
    "anchor:deploy": "dotenv -e .env.local -- bash -c 'anchor deploy --provider.wallet ${ANCHOR_WALLET} --program-name domin8_prgm --program-id ${ANCHOR_PROGRAM_ID}'",
    "anchor:localnet": "anchor localnet",
    "cap:sync": "npx cap sync",
    "cap:build": "bun run build && npx cap sync",
    "cap:android": "npx cap open android",
    "cap:run:android": "npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@coral-xyz/anchor": "0.31.1",
    "@metaplex-foundation/js": "^0.20.1",
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
    "@privy-io/react-auth": "^3.0.1",
    "@privy-io/server-auth": "^1.32.5",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@solana-mobile/mobile-wallet-adapter-protocol-web3js": "^2.2.5",
    "@solana-mobile/wallet-adapter-mobile": "^2.2.5",
    "@solana-mobile/wallet-standard-mobile": "^0.4.4",
    "@solana-program/memo": "^0.8.0",
    "@solana-program/system": "^0.8.0",
    "@solana-program/token": "^0.6.0",
    "@solana/connector": "^0.2.1",
    "@solana/kit": "^3.0.3",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/web3.js": "^1.98.4",
    "@switchboard-xyz/on-demand": "^3.6.0",
    "@types/bn.js": "^5.2.0",
    "@vercel/analytics": "^1.5.0",
    "@wallet-standard/app": "^1.1.0",
    "bn.js": "^5.2.2",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.29.1",
    "lucide-react": "^0.544.0",
    "next-themes": "^0.4.6",
    "phaser": "^3.90.0",
    "react": "^19.0.0",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.9.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tweetnacl": "^1.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@solana/spl-token": "^0.4.14",
    "@tailwindcss/vite": "^4.0.14",
    "@types/node": "^24.5.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.3.4",
    "chai": "^6.2.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "mocha": "^11.7.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.0.14",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.3.8",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^7.2.2",
    "vite-plugin-node-polyfills": "^0.24.0"
  }
}
