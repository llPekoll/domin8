{
  "name": "blood",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite --open",
    "dev:backend": "convex dev",
    "predev": "convex dev --until-success && convex dashboard",
    "build": "tsc -b && vite build",
    "lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "script:initialize": "node scripts/initialize-standalone.mjs",
    "script:initialize:devnet": "node scripts/initialize-standalone.mjs --cluster=devnet",
    "script:initialize:ts": "ts-node scripts/initialize-game.ts",
    "script:initialize:cjs": "node scripts/initialize-game.cjs",
    "anchor:test": "dotenv -e .env.local -- bash -c 'anchor test --provider.wallet ${ANCHOR_WALLET} --program-name domin8_prgm --program-id ${ANCHOR_PROGRAM_ID}'",
    "anchor:test:skip": "dotenv -e .env.local -- bash -c 'anchor test --skip-build --skip-deploy --provider.wallet ${ANCHOR_WALLET}'",
    "anchor:build": "dotenv -e .env.local -- bash -c 'anchor build'",
    "anchor:deploy": "dotenv -e .env.local -- bash -c 'anchor deploy --provider.wallet ${ANCHOR_WALLET} --program-name domin8_prgm --program-id ${ANCHOR_PROGRAM_ID}'",
    "anchor:localnet": "anchor localnet"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.31.1",
    "@metaplex-foundation/js": "^0.20.1",
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
    "@privy-io/react-auth": "^3.8.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@solana-program/memo": "^0.8.0",
    "@solana-program/system": "^0.8.1",
    "@solana-program/token": "^0.6.0",
    "@solana/kit": "^3.0.3",
    "@solana/web3.js": "^1.98.4",
    "@types/bn.js": "^5.2.0",
    "@vercel/analytics": "^1.6.1",
    "bn.js": "^5.2.2",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.31.0",
    "lucide-react": "^0.544.0",
    "next-themes": "^0.4.6",
    "phaser": "^3.90.0",
    "react": "^19.2.3",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.10.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@solana/spl-token": "^0.4.14",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "chai": "^6.2.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.25",
    "globals": "^15.15.0",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.18",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.3.0",
    "vite-plugin-node-polyfills": "^0.24.0"
  }
}
